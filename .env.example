# Pinterest Pipeline — Environment Variables
# Copy this file to .env and fill in actual values.
# NEVER commit .env to Git.

# --- Pinterest API ---
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_ACCESS_TOKEN=
PINTEREST_REFRESH_TOKEN=

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=

# --- Image Generation ---
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5-mini    # Override OpenAI model for pin copy / image prompts
REPLICATE_API_TOKEN=

# --- Stock Photo APIs ---
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=

# --- Google Sheets ---
GOOGLE_SHEETS_CREDENTIALS_JSON=  # Base64-encoded service account JSON
GOOGLE_SHEET_ID=                 # From the Sheet URL
GOOGLE_SHEET_URL=                # Full URL for Slack notification links

# --- GitHub (for blog deployment to goslated.com) ---
GOSLATED_GITHUB_TOKEN=           # PAT with repo write access
GOSLATED_REPO=                   # e.g., "your-org/goslated.com"

# --- Slack ---
SLACK_WEBHOOK_URL=
