# Rendered pin PNGs are large (~2-5MB) and uploaded to GCS — don't commit them.
# Blog MDX files and hero images MUST be committed (deploy-to-preview reads them from git).
*.png
!data/generated/pins/*-hero.png
!data/generated/blog/*.png
!templates/pins/shared/brand-elements/*.png

